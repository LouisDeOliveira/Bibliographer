# ─── Backend selector ────────────────────────────────────────────────────────
# "huggingface"  → uses HuggingFace Inference API  (free tier available)
# "litellm"      → routes through LiteLLM to any provider
LLM_BACKEND=huggingface

# ─── HuggingFace Inference API ───────────────────────────────────────────────
# Get your token at https://huggingface.co/settings/tokens
# Models with reliable JSON output:
#   Qwen/Qwen2.5-72B-Instruct          (best JSON, free serverless)
#   meta-llama/Meta-Llama-3.1-8B-Instruct
#   mistralai/Mistral-7B-Instruct-v0.3
HF_TOKEN=hf_REPLACE_ME
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# ─── LiteLLM ────────────────────────────────────────────────────────────────
# Model string follows LiteLLM format: provider/model-name
# Examples: gpt-4o-mini, anthropic/claude-haiku-4-5, groq/llama3-8b-8192,
#           ollama/mistral (for local Ollama)
LITELLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-REPLACE_ME
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# GROQ_API_KEY=gsk_REPLACE_ME

# ─── Academic APIs ───────────────────────────────────────────────────────────
# Semantic Scholar — no key needed for basic use, but register for higher limits
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
